[gd_resource type="Theme" load_steps=5 format=3]

[ext_resource type="FontFile" path="res://fonts/NotoSans.ttf" id="1"]
[ext_resource type="FontFile" path="res://fonts/NotoEmoji.ttf" id="2"]

[sub_resource type="FontVariation" id="FontVariation_1"]
base_font = ExtResource("1")
fallbacks = Array[Font]([ExtResource("2")])

[sub_resource type="FontVariation" id="FontVariation_bold"]
base_font = ExtResource("1")
fallbacks = Array[Font]([ExtResource("2")])
variation_opentype = {
	"wght": 700
}

[resource]
default_font = SubResource("FontVariation_1")
default_font_size = 24
Label/fonts/bold_font = SubResource("FontVariation_bold")
